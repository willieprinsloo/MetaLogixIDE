# electron-builder can't traverse pnpm's .pnpm/ symlink layout when it
# copies production dependencies — transitive runtime deps of our native
# modules (better-sqlite3 -> bindings -> file-uri-to-path) go missing in
# the packaged .app and boot crashes with "Cannot find module 'bindings'".
#
# Lay out node_modules flat (like npm/yarn) so electron-builder finds
# every transitive dep. This is the standard Electron + pnpm recipe.
# We keep pnpm's lockfile and CAS for correctness and speed; only the
# on-disk layout changes.
node-linker=hoisted
shamefully-hoist=true
