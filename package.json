{
  "name": "metaide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "main": "out/main/index.js",
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "rebuild:node": "pnpm rebuild better-sqlite3 node-pty",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:full": "electron-vite build && electron-rebuild -f -w better-sqlite3 -w node-pty && playwright test && pnpm rebuild better-sqlite3 node-pty",
    "mock-claude": "node scripts/mock-claude.mjs",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64 --x64",
    "dist:mac-arm": "electron-vite build && electron-builder --mac --arm64",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "dist:linux": "electron-vite build && electron-builder --linux --x64",
    "dist:all": "node scripts/dist-all.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "postinstall": "test -d node_modules/node-pty/prebuilds/darwin-arm64 && chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper || true"
  },
  "build": {
    "appId": "com.metalogix.metaide",
    "productName": "MetaLogix IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "migrations/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,test,__tests__,tests,powered-test,example,examples,*.d.ts,tsconfig*.json}",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/keytar/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "sign": false,
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.11.1",
    "keytar": "^7.9.0",
    "markdown-it": "^14.3.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.47.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
